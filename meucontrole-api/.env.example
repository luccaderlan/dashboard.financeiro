# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Obtenha a connection string no painel do Supabase:
# https://supabase.com → Project → Settings → Database → Connection String (URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="seu_jwt_secret_aqui_minimo_64_caracteres"
JWT_REFRESH_SECRET="seu_refresh_secret_aqui_diferente_do_jwt_secret"

# Duração dos tokens (padrão: 15m access, 7d refresh)
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Cookie ────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET="seu_cookie_secret_aqui_minimo_32_caracteres"

# ─── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3333
HOST="0.0.0.0"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Em produção: URL exata do frontend (sem barra final)
FRONTEND_URL="http://localhost:5173"

# ─── E-mail (Resend) ───────────────────────────────────────────────────────────
# Obtenha em https://resend.com → API Keys
# Em desenvolvimento, deixar em branco — e-mails serão logados no console
RESEND_API_KEY=""
EMAIL_FROM="MeuControle <noreply@seudominio.com.br>"
